# RPC endpoint (BNB Chain mainnet)
RPC_URL=https://bsc-dataseed.binance.org/

# Solver wallet private key (must hold CTF tokens + USDT for filling requests)
PRIVATE_KEY=0x...

# Presage contract address
PRESAGE_ADDRESS=0x...

# Morpho Blue address on BNB Chain
MORPHO_ADDRESS=0x01b0Bd309AA75547f7a37Ad7B1219A898E67a83a

# Market IDs to monitor (comma-separated)
MARKET_IDS=1,2,3

# predict.fun API base URL
PREDICT_API_URL=https://api.predict.fun

# predict.fun API key (optional, for higher rate limits)
# PREDICT_API_KEY=

# Acquire mode: "inventory" (only fill from existing CTF balance) or
# "jit" (just-in-time: buy CTF from predict.fun orderbook before filling).
# Default: inventory
ACQUIRE_MODE=inventory

# Max slippage when buying CTF from predict.fun (in bps). Only used in JIT mode.
JIT_SLIPPAGE_BPS=100

# Max time (seconds) to wait for a predict.fun order to fill before giving up.
JIT_FILL_TIMEOUT_SECONDS=30

# Minimum profit threshold (in USDT, 18 decimals). Bot won't fill requests
# that yield less than this amount after gas.
MIN_PROFIT_USDT=1.0

# Poll interval in seconds (how often to check for new requests)
POLL_INTERVAL_SECONDS=5

# Gas price limit in gwei (skip filling if gas is above this)
MAX_GAS_PRICE_GWEI=10
