{
  "name": "presage-protocol",
  "version": "0.1.0",
  "description": "Borrow stablecoins against prediction market CTF tokens via Morpho Blue",
  "license": "UNLICENSED",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:integration": "hardhat test test/Presage.integration.test.ts --network bnbTestnet",
    "test:fork": "hardhat test test/Presage.fork.test.ts --network hardhat",
    "test:vault": "hardhat test test/Presage.vault.fork.test.ts --network hardhat",
    "test:allocator": "hardhat test test/allocator.strategy.test.ts --no-compile",
    "test:mainnet": "hardhat test test/Presage.mainnet.test.ts --network bnb",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network bnbTestnet",
    "deploy:bnb": "hardhat run scripts/deploy.ts --network bnb",
    "clean": "hardhat clean",
    "playground": "node playground/start.cjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.4.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@predictdotfun/sdk": "^1.3.0",
    "@reclaimprotocol/js-sdk": "^4.15.0",
    "@reclaimprotocol/verifier-solidity-sdk": "^1.0.4",
    "@reclaimprotocol/zk-fetch": "^0.8.0"
  }
}
